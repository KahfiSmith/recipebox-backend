                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password/reset",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "password",
                "reset"
              ]
            },
            "description": "Reset password using one-time token."
          }
        }
      ]
