APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://user:pass@localhost:5432/recipebox?sslmode=disable
JWT_SECRET=replace-with-at-least-32-characters-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
BCRYPT_COST=12
GRACEFUL_SHUTDOWN_MS=10000

FRONTEND_BASE_URL=http://localhost:3000
AUTH_DEBUG_EXPOSE_TOKENS=false
AUTH_RATE_LIMIT_PER_MINUTE=30

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxx
SMTP_FROM_EMAIL=no-reply@your-verified-domain.com
SMTP_FROM_NAME=RecipeBox
